# ---------------------------------------------------------------------------
# IMPORTANT: dist/ is intentionally NOT ignored.
# GitHub Actions written in Node run the committed dist/index.js directly -
# there is no install step at runtime. CI enforces that dist/ is in sync
# with src/ via `git diff --exit-code dist/` after a clean build.
# Do NOT add dist/ to this file.
# ---------------------------------------------------------------------------
